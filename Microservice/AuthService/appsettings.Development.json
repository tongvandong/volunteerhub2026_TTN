{
  "Database": {
    "EnsureCreatedOnStartup": true
  },
  "Jwt": {
    "Issuer": "VolunteerHub.AuthService",
    "Audience": "VolunteerHub",
    "SigningKey": "development-signing-key-for-volunteerhub-auth-service",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
